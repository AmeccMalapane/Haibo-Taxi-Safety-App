{
  "expo": {
    "name": "Haibo! App",
    "slug": "haibo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "haibo-taxi",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.haibo.africa.haiboapp",
      "associatedDomains": [
        "applinks:haibo.africa",
        "applinks:www.haibo.africa"
      ],
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["haibo-taxi"]
          }
        ],
        "LSApplicationQueriesSchemes": ["haibo-taxi"]
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.haibo.africa.haiboapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "haibo.africa",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.haibo.africa",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "haibo-taxi"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "SEND",
          "data": [
            {
              "mimeType": "text/plain"
            }
          ],
          "category": ["DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.18.2"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Haibo! uses your location to find nearby taxi ranks, share your position during an SOS alert, and show ride routes on the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Haibo! needs access to your photos so you can upload a profile picture, verification documents, and images for community posts, ratings, and reports.",
          "cameraPermission": "Haibo! needs access to your camera so you can take a profile picture, capture driver verification documents, and add photos to community posts, ratings, and reports."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "4304f120-f88f-4752-885a-ed316817d9b7"
      }
    }
  }
}
