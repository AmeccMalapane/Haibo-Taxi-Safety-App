# ============================================
# HAIBO APP — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================

# --- Server ---
NODE_ENV=development
PORT=8080
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,https://haibo-api-prod.azurewebsites.net

# --- Database (Neon / Azure PostgreSQL) ---
DATABASE_URL=postgresql://haiboadmin:YOUR_PASSWORD@haibo-db-prod.postgres.database.azure.com:5432/haibo_prod?sslmode=require

# --- Authentication ---
JWT_SECRET=CHANGE_ME_TO_A_SECURE_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_SECURE_64_CHAR_RANDOM_STRING

# --- Mapbox ---
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN_HERE

# --- Paystack ---
PAYSTACK_SECRET_KEY=sk_test_YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_test_1652390c7d5a1cc8d50b67bcc185cc064c00f805
PAYSTACK_WEBHOOK_SECRET=YOUR_PAYSTACK_WEBHOOK_SECRET

# --- Firebase (Push Notifications) ---
FIREBASE_PROJECT_ID=haibo-app-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@haibo-app-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# --- Azure Blob Storage ---
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=sthaibomedia;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_COMMUNITY=community-media
AZURE_STORAGE_CONTAINER_EVENTS=event-posters
AZURE_STORAGE_CONTAINER_DRIVERS=driver-photos

# --- Azure SignalR (Real-Time) ---
AZURE_SIGNALR_CONNECTION_STRING=Endpoint=https://haibo-signalr-prod.service.signalr.net;AccessKey=YOUR_KEY;Version=1.0;

# --- Azure Communication Services (EMAIL only — SMS moved to BulkSMS) ---
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://haibo-comms-prod.africa.communication.azure.com/;accesskey=YOUR_KEY
AZURE_COMMUNICATION_SENDER_EMAIL=DoNotReply@haibo.africa

# --- BulkSMS (SA-native SMS aggregator) ---
# Create a token at https://www.bulksms.com/ → Settings → API tokens.
# Sender is an alphanumeric ID up to 11 chars; falls back to "HAIBO" if unset.
BULKSMS_TOKEN_ID=YOUR_BULKSMS_TOKEN_ID
BULKSMS_TOKEN_SECRET=YOUR_BULKSMS_TOKEN_SECRET
BULKSMS_SENDER=HAIBO

# --- Expo (Client) ---
EXPO_PUBLIC_DOMAIN=haibo-api-prod.azurewebsites.net
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_1652390c7d5a1cc8d50b67bcc185cc064c00f805

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
