{
  "expo": {
    "name": "Haibo!",
    "slug": "haibo-taxi-safety",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E72369"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.haibo.taxisafety",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Haibo needs your location to find nearby taxi ranks and share your trip with emergency contacts.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Haibo uses background location to track your taxi journey and alert emergency contacts.",
        "NSCameraUsageDescription": "Haibo needs camera access to report incidents and capture evidence.",
        "NSMicrophoneUsageDescription": "Haibo needs microphone access for audio evidence recording.",
        "NSContactsUsageDescription": "Haibo needs contacts access to set up emergency contacts."
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E72369"
      },
      "package": "com.haibo.taxisafety",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_CONTACTS",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      "expo-haptics",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E72369"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
