  "validation_rules": {
    "fare_validation": [
      {
        "rule_id": "FARE-001",
        "name": "positive_value",
        "description": "Fare amount must be greater than zero",
        "severity": "critical",
        "error_message": "Fare amount must be positive",
        "implementation": "amount > 0"
      },
      {
        "rule_id": "FARE-002",
        "name": "reasonable_range",
        "description": "Fare must be within reasonable bounds for distance",
        "severity": "warning",
        "error_message": "Fare appears unusually high/low for route distance",
        "implementation": "amount >= (distance_km * 0.5) AND amount <= (distance_km * 5)"
      },
      {
        "rule_id": "FARE-003",
        "name": "percentage_increase_limit",
        "description": "Fare increase cannot exceed 20% without verification",
        "severity": "warning",
        "error_message": "Fare increase exceeds normal limits",
        "implementation": "new_amount <= (previous_amount * 1.2)"
      },
      {
        "rule_id": "FARE-004",
        "name": "multiple_reports_consistency",
        "description": "Multiple user reports should show fare consistency",
        "severity": "info",
        "error_message": "Fare reports vary significantly",
        "implementation": "stddev(reported_amounts) < (average_amount * 0.15)"
      }
    ],
    "safety_report_validation": [
      {
        "rule_id": "SAFETY-001",
        "name": "location_verification",
        "description": "Report location must be within operational area",
        "severity": "warning",
        "error_message": "Report location appears outside route area",
        "implementation": "distance(location, route_path) < 5km"
      },
      {
        "rule_id": "SAFETY-002",
        "name": "user_reputation_check",
        "description": "Check user's previous report accuracy",
        "severity": "info",
        "error_message": "User has low accuracy rating",
        "implementation": "user_accuracy_score > 0.7"
      },
      {
        "rule_id": "SAFETY-003",
        "name": "evidence_validation",
        "description": "Check for supporting evidence in high-severity reports",
        "severity": "warning",
        "error_message": "High severity report lacks supporting evidence",
        "implementation": "severity != 'high' OR evidence_files_count > 0"
      },
      {
        "rule_id": "SAFETY-004",
        "name": "duplicate_report_check",
        "description": "Check for similar recent reports",
        "severity": "info",
        "error_message": "Similar report already submitted",
        "implementation": "similar_reports_count < 3"
      }
    ],
    "route_validation": [
      {
        "rule_id": "ROUTE-001",
        "name": "duplicate_route_check",
        "description": "Check for existing similar routes",
        "severity": "warning",
        "error_message": "Similar route already exists",
        "implementation": "distance(starting_point, existing_start) > 1km OR distance(destination, existing_dest) > 1km"
      },
      {
        "rule_id": "ROUTE-002",
        "name": "geographic_feasibility",
        "description": "Route must be geographically feasible",
        "severity": "critical",
        "error_message": "Route appears geographically impossible",
        "implementation": "distance_km / estimated_hours < 200"
      },
      {
        "rule_id": "ROUTE-003",
        "name": "time_distance_ratio",
        "description": "Travel time must be reasonable for distance",
        "severity": "warning",
        "error_message": "Travel time unrealistic for distance",
        "implementation": "estimated_hours >= (distance_km / 100) AND estimated_hours <= (distance_km / 20)"
      }
    ],
    "general_validation": [
      {
        "rule_id": "GEN-001",
        "name": "timestamp_recency",
        "description": "Data must be recent (within 2 years)",
        "severity": "warning",
        "error_message": "Data appears outdated",
        "implementation": "timestamp > NOW() - INTERVAL '2 years'"
      },
      {
        "rule_id": "GEN-002",
        "name": "required_fields_check",
        "description": "All required fields must be populated",
        "severity": "critical",
        "error_message": "Required field missing",
        "implementation": "required_fields IS NOT NULL"
      },
      {
        "rule_id": "GEN-003",
        "name": "format_validation",
        "description": "Field values must match expected format",
        "severity": "warning",
        "error_message": "Field format incorrect",
        "implementation": "FIELD REGEXP 'expected_pattern'"
      }
    ]
  },

