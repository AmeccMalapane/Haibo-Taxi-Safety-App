{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "CI": "false",
        "EXPO_PUBLIC_DOMAIN": "haibo-api-prod.azurewebsites.net"
      },
      "withoutCredentials": true,
      "developmentClient": false
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "CI": "false",
        "EXPO_PUBLIC_DOMAIN": "haibo-api-prod.azurewebsites.net"
      },
      "autoIncrement": true,
      "developmentClient": false
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
